---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const features = [
  {
    icon: '⚛️',
    title: '最小的分子',
    desc: 'H₂ 是宇宙中最小的分子，能穿透細胞膜、血腦屏障，到達其他抗氧化劑無法抵達的地方。',
    tag: '基礎科學',
  },
  {
    icon: '🛡️',
    title: '選擇性抗氧化',
    desc: '分子氫只與最毒的活性氧（OH·、ONOO⁻）反應，不影響生理必需的 H₂O₂。',
    tag: '機制研究',
  },
  {
    icon: '✓',
    title: '安全性極高',
    desc: '人體本身腸道菌群每天就會產生氫氣，飲用氫水的安全性已在多項人體試驗中確認。',
    tag: '安全評估',
  },
];

const evidenceLevels = [
  {
    badge: 'strong',
    emoji: '✅',
    level: '強證據',
    grade: 'A',
    desc: '多篇人體隨機對照試驗（RCT），樣本數充足，結果一致。',
  },
  {
    badge: 'preliminary',
    emoji: '🔬',
    level: '初步證據',
    grade: 'B',
    desc: '少量人體研究或動物實驗，有潛力但需更多驗證。',
  },
  {
    badge: 'insufficient',
    emoji: '⚠️',
    level: '證據不足',
    grade: 'C',
    desc: '缺乏足夠規模的研究，目前無法得出可靠結論。',
  },
  {
    badge: 'ineffective',
    emoji: '❌',
    level: '無效',
    grade: 'D',
    desc: '研究顯示無明顯效果，或機制上不合理。',
  },
];
---

<BaseLayout
  title="H2 Water Lab | 氫水科學研究室"
  description="用科學數據解答氫水的每一個疑問。整合 PubMed 臨床研究，幫你做出有根據的健康選擇。"
>
  <!-- ============ HERO ============ -->
  <section class="hero-section">
    <div class="max-w-6xl mx-auto px-6 w-full relative z-10">
      <div class="max-w-xl">
        <!-- Tagline pill -->
        <div style="display: inline-flex; align-items: center; gap: 8px; background: rgba(8,145,178,0.08); border: 1px solid rgba(8,145,178,0.2); border-radius: 100px; padding: 4px 14px; margin-bottom: 1.5rem;">
          <span style="width: 6px; height: 6px; background: var(--color-aqua); border-radius: 50%; display: block;"></span>
          <span style="font-size: 0.78rem; font-weight: 500; color: var(--color-aqua-dark); letter-spacing: 0.04em;">氫水研究室 · 科學實證</span>
        </div>

        <h1 class="hero-title" style="margin-bottom: 1.25rem;">
          用科學，<br />重新認識水
        </h1>
        <p class="hero-subtitle" style="max-width: 440px; margin-bottom: 2rem;">
          整合 PubMed 臨床研究，<br />
          給你不偏不倚的氫水科學答案。<br />
          每個宣稱，都有論文為證。
        </p>
        <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
          <a href="/blog" class="btn btn-primary">探索研究文章 →</a>
          <a href="/categories" class="btn btn-secondary">按分類瀏覽</a>
        </div>
      </div>
    </div>

    <!-- Water Molecule SVG Decoration -->
    <svg class="water-molecule-svg" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <!-- Central H₂O cluster -->
      <circle cx="200" cy="200" r="28" stroke="#0891B2" stroke-width="2"/>
      <circle cx="290" cy="140" r="20" stroke="#0891B2" stroke-width="2"/>
      <circle cx="130" cy="130" r="16" stroke="#22D3EE" stroke-width="1.5"/>
      <circle cx="310" cy="270" r="22" stroke="#0891B2" stroke-width="2"/>
      <circle cx="120" cy="280" r="14" stroke="#22D3EE" stroke-width="1.5"/>
      <circle cx="240" cy="320" r="12" stroke="#5EEAD4" stroke-width="1.5"/>
      <circle cx="80" cy="200" r="10" stroke="#5EEAD4" stroke-width="1.5"/>
      <circle cx="350" cy="190" r="10" stroke="#5EEAD4" stroke-width="1.5"/>
      <!-- Bonds -->
      <line x1="200" y1="200" x2="290" y2="140" stroke="#0891B2" stroke-width="1.5" stroke-dasharray="4 3"/>
      <line x1="200" y1="200" x2="130" y2="130" stroke="#22D3EE" stroke-width="1" stroke-dasharray="4 3"/>
      <line x1="200" y1="200" x2="310" y2="270" stroke="#0891B2" stroke-width="1.5" stroke-dasharray="4 3"/>
      <line x1="200" y1="200" x2="120" y2="280" stroke="#22D3EE" stroke-width="1" stroke-dasharray="4 3"/>
      <line x1="200" y1="200" x2="240" y2="320" stroke="#5EEAD4" stroke-width="1" stroke-dasharray="4 3"/>
      <line x1="200" y1="200" x2="80" y2="200" stroke="#5EEAD4" stroke-width="1" stroke-dasharray="4 3"/>
      <line x1="200" y1="200" x2="350" y2="190" stroke="#5EEAD4" stroke-width="1" stroke-dasharray="4 3"/>
      <line x1="290" y1="140" x2="310" y2="270" stroke="#0891B2" stroke-width="1" stroke-dasharray="3 4" opacity="0.5"/>
      <!-- Labels -->
      <text x="192" y="205" font-family="JetBrains Mono, monospace" font-size="13" fill="#0891B2" text-anchor="middle">H₂</text>
      <text x="290" y="145" font-family="JetBrains Mono, monospace" font-size="10" fill="#0891B2" text-anchor="middle">O</text>
      <text x="310" y="275" font-family="JetBrains Mono, monospace" font-size="11" fill="#0891B2" text-anchor="middle">H₂O</text>
    </svg>
  </section>

  <!-- ============ WHY H₂ ============ -->
  <section class="section" style="background: var(--color-mist);">
    <div class="max-w-6xl mx-auto px-6">
      <div style="text-align: center; margin-bottom: 3rem;">
        <h2 class="section-title">為什麼是氫水？</h2>
        <p class="section-subtitle">分子氫（H₂）三個不容忽視的科學特性</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {features.map(f => (
          <div class="feature-card">
            <span class="feature-icon">{f.icon}</span>
            <div style="display: inline-flex; margin-bottom: 0.75rem;">
              <span class="tag tag-aqua">{f.tag}</span>
            </div>
            <h3 class="feature-title">{f.title}</h3>
            <p class="feature-desc">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ============ LATEST ARTICLES ============ -->
  <section class="section">
    <div class="max-w-6xl mx-auto px-6">
      <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem;">
        <div>
          <h2 class="section-title">最新研究文章</h2>
          <p class="section-subtitle">每篇都附論文出處與證據等級評分</p>
        </div>
        <a href="/blog" class="btn btn-secondary" style="font-size: 0.8rem;">查看全部文章 →</a>
      </div>

      {posts.length === 0 ? (
        <div style="text-align: center; padding: 4rem 0; color: var(--color-slate);">
          <p style="font-size: 1.5rem; margin-bottom: 0.5rem;">🔬</p>
          <p>研究文章整理中，敬請期待…</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}`} class="article-card" style="text-decoration: none;">
              <!-- Card Image Placeholder (16:9) -->
              <div style="aspect-ratio: 16/9; background: linear-gradient(135deg, var(--color-mist) 0%, #E0F2FE 100%); display: flex; align-items: center; justify-content: center; color: var(--color-aqua); font-size: 2rem;">
                🧪
              </div>
              <div class="article-card-body">
                <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; flex-wrap: wrap;">
                  <span class="tag tag-mint">{post.data.category}</span>
                  <span style="font-size: 0.75rem; color: var(--color-slate);">
                    {post.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </span>
                </div>
                <h3 style="font-size: 1rem; font-weight: 700; color: var(--color-ink); line-height: 1.5; margin-bottom: 0.625rem; flex: 1;">
                  {post.data.title}
                </h3>
                <p style="font-size: 0.85rem; color: var(--color-slate); line-height: 1.6; margin-bottom: 1rem; flex: 1;">
                  {post.data.description}
                </p>
                <div style="font-size: 0.8rem; color: var(--color-aqua); font-weight: 500; margin-top: auto;">
                  閱讀全文 →
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ============ EVIDENCE LEVEL EXPLAINER ============ -->
  <section class="section" style="background: var(--color-mist);">
    <div class="max-w-6xl mx-auto px-6">
      <div style="text-align: center; margin-bottom: 3rem;">
        <h2 class="section-title">本站的證據等級系統</h2>
        <p class="section-subtitle">每個健康宣稱都必須標注等級 — 讓你一眼判斷可信度</p>
      </div>

      <div class="evidence-legend">
        {evidenceLevels.map(item => (
          <div class="evidence-legend-item">
            <span class={`evidence-badge ${item.badge}`} style="flex-shrink: 0;">
              {item.emoji} {item.level}
            </span>
            <div>
              <p class="evidence-legend-desc">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <p style="text-align: center; margin-top: 2rem; font-size: 0.85rem; color: var(--color-slate);">
        等級評定參考標準：GRADE system、Cochrane 系統性回顧方法論
      </p>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ============ CTA BANNER ============ -->
  <section class="section">
    <div class="max-w-6xl mx-auto px-6">
      <div class="cta-banner">
        <p style="font-size: 0.78rem; letter-spacing: 0.1em; opacity: 0.7; margin-bottom: 0.5rem; font-weight: 500; text-transform: uppercase;">Science-backed Research</p>
        <h2>探索氫水科學，做出聰明的健康決策</h2>
        <p>不被廣告牽著走。讓論文告訴你真正的答案。</p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <a href="/blog" class="btn" style="background: white; color: var(--color-aqua-dark); border: 1.5px solid white;">瀏覽所有研究文章</a>
          <a href="/categories" class="btn" style="background: transparent; color: white; border: 1.5px solid rgba(255,255,255,0.5);">按分類探索</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
