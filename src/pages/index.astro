---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const latestPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' });
}

function evidenceBadgeClass(level?: string) {
  const map: Record<string, string> = {
    strong: 'strong',
    preliminary: 'preliminary',
    insufficient: 'insufficient',
    ineffective: 'ineffective',
  };
  return level ? map[level] : 'preliminary';
}

function evidenceBadgeLabel(level?: string) {
  const map: Record<string, string> = {
    strong: '強證據',
    preliminary: '初步證據',
    insufficient: '證據不足',
    ineffective: '無效',
  };
  return level ? map[level] : '初步證據';
}

function eviSvg(key: string, size = 13, color = 'currentColor') {
  const svgs: Record<string, string> = {
    strong: `<svg width="${size}" height="${size}" viewBox="0 0 14 14" fill="none" stroke="${color}" stroke-width="1.3" stroke-linecap="square"><circle cx="7" cy="7" r="5.5"/><circle cx="7" cy="7" r="2" fill="${color}" stroke="none"/></svg>`,
    preliminary: `<svg width="${size}" height="${size}" viewBox="0 0 14 14" fill="none" stroke="${color}" stroke-width="1.3" stroke-linecap="square"><circle cx="7" cy="7" r="5.5"/><path d="M7 1.5 A5.5 5.5 0 0 0 7 12.5 Z" fill="${color}" stroke="none"/></svg>`,
    insufficient: `<svg width="${size}" height="${size}" viewBox="0 0 14 14" fill="none" stroke="${color}" stroke-width="1.3" stroke-linecap="square"><path d="M9.5 2.2 A5.5 5.5 0 1 1 4.5 2.2"/></svg>`,
    ineffective: `<svg width="${size}" height="${size}" viewBox="0 0 14 14" fill="none" stroke="${color}" stroke-width="1.3" stroke-linecap="square"><circle cx="7" cy="7" r="5.5"/><line x1="3.5" y1="3.5" x2="10.5" y2="10.5"/></svg>`,
  };
  return svgs[key] ?? '';
}

const evidenceColors: Record<string, { color: string; bg: string }> = {
  strong:       { color: '#059669', bg: '#ECFDF5' },
  preliminary:  { color: '#2563EB', bg: '#EFF6FF' },
  insufficient: { color: '#D97706', bg: '#FFFBEB' },
  ineffective:  { color: '#DC2626', bg: '#FEF2F2' },
};
---

<BaseLayout
  title="H₂ Water Lab 氫水科學研究室 — 用科學，重新認識水"
  description="H₂ Water Lab 以嚴謹的科學態度評估氫水研究，提供台灣讀者正確、可驗證的健康資訊。每篇文章標註科學證據等級。"
>
  <!-- ====== HERO ====== -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container">
      <div class="hero-inner">
        <div class="hero-content">
          <span class="hero-eyebrow">氫水科學研究室</span>
          <h1 class="hero-display-title">
            用科學，<br />
            <span class="accent">重新認識水</span>
          </h1>
          <p class="hero-subtitle-ja">
            H₂ Water Lab 以嚴謹的科學態度評估氫水相關研究，<br />
            提供台灣讀者正確、可驗證的健康資訊。
          </p>
          <div class="hero-actions">
            <a href="/blog/" class="btn btn--primary btn--lg">瀏覽科學文章</a>
            <a href="/about/#methodology" class="btn btn--secondary btn--lg">我們的方法論</a>
          </div>
        </div>

        <!-- Water Molecule SVG Decoration -->
        <div class="hero-decoration" aria-hidden="true">
          <svg
            width="360"
            height="360"
            viewBox="0 0 360 360"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <!-- Outer ring hint -->
            <circle cx="180" cy="180" r="155" stroke="#CBD5E1" stroke-width="1" stroke-dasharray="4 8" opacity="0.4"/>

            <!-- Molecule bonds -->
            <line x1="120" y1="180" x2="180" y2="120" stroke="#94A3B8" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="180" y1="120" x2="240" y2="180" stroke="#94A3B8" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="240" y1="180" x2="210" y2="255" stroke="#94A3B8" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="180" y1="120" x2="180" y2="55" stroke="#94A3B8" stroke-width="2" stroke-linecap="round"/>
            <line x1="120" y1="180" x2="55" y2="165" stroke="#94A3B8" stroke-width="2" stroke-linecap="round"/>
            <line x1="240" y1="180" x2="305" y2="165" stroke="#94A3B8" stroke-width="2" stroke-linecap="round"/>

            <!-- Central O atom (large) -->
            <circle cx="180" cy="120" r="36" fill="url(#gradCenter)" opacity="0.92"/>
            <text x="180" y="126" text-anchor="middle" font-size="18" font-weight="700" font-family="'JetBrains Mono', monospace" fill="white">O</text>

            <!-- H atoms -->
            <circle cx="120" cy="180" r="26" fill="url(#gradH1)" opacity="0.88"/>
            <text x="120" y="186" text-anchor="middle" font-size="14" font-weight="700" font-family="'JetBrains Mono', monospace" fill="white">H</text>

            <circle cx="240" cy="180" r="26" fill="url(#gradH2)" opacity="0.88"/>
            <text x="240" y="186" text-anchor="middle" font-size="14" font-weight="700" font-family="'JetBrains Mono', monospace" fill="white">H</text>

            <!-- Smaller accent atoms -->
            <circle cx="210" cy="255" r="18" fill="#5EEAD4" opacity="0.5"/>
            <circle cx="180" cy="55" r="14" fill="#22D3EE" opacity="0.45"/>
            <circle cx="55" cy="165" r="14" fill="#22D3EE" opacity="0.35"/>
            <circle cx="305" cy="165" r="14" fill="#22D3EE" opacity="0.35"/>

            <!-- H₂ label near bottom -->
            <text x="210" y="259" text-anchor="middle" font-size="9" font-weight="700" font-family="'JetBrains Mono', monospace" fill="#0F172A" opacity="0.6">H₂</text>

            <defs>
              <radialGradient id="gradCenter" cx="40%" cy="35%">
                <stop offset="0%" stop-color="#22D3EE"/>
                <stop offset="100%" stop-color="#0891B2"/>
              </radialGradient>
              <radialGradient id="gradH1" cx="40%" cy="35%">
                <stop offset="0%" stop-color="#38BDF8"/>
                <stop offset="100%" stop-color="#0284C7"/>
              </radialGradient>
              <radialGradient id="gradH2" cx="40%" cy="35%">
                <stop offset="0%" stop-color="#38BDF8"/>
                <stop offset="100%" stop-color="#0284C7"/>
              </radialGradient>
            </defs>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== WHY H₂ ====== -->
  <section class="section" style="background: white;">
    <div class="container">
      <div class="section-header centered">
        <span class="section-label">為什麼是氫水？</span>
        <h2 class="section-title">H₂ 的三個科學特性</h2>
        <p class="section-desc">
          不是每一種健康水都有科學依據。了解氫水為什麼值得關注。
        </p>
      </div>

      <div class="feature-grid">
        <!-- Feature 1 -->
        <div class="feature-card reveal">
          <div class="feature-icon" style="font-size: 28px; color: var(--color-primary-500); opacity: 0.7;">H₂</div>
          <h3 class="feature-title">自然界最小分子</h3>
          <p class="feature-desc">
            H₂ 是自然界中最小的分子，可穿透細胞膜甚至血腦屏障，直接到達細胞內部。這是其他抗氧化物質難以做到的。
          </p>
          <div style="margin-top: var(--space-4);">
            <span style="font-family: var(--font-family-mono); font-size: 11px; color: var(--color-primary-600); background: var(--color-primary-50); padding: 3px 8px; border-radius: 4px;">MW: 2.016 g/mol</span>
          </div>
        </div>

        <!-- Feature 2 -->
        <div class="feature-card reveal reveal-delay-1">
          <div class="feature-icon" style="font-size: 28px; color: var(--color-primary-500); opacity: 0.7;">·OH</div>
          <h3 class="feature-title">選擇性抗氧化</h3>
          <p class="feature-desc">
            H₂ 只中和有害的羥自由基（·OH）和過氧亞硝酸根（ONOO⁻），不影響人體需要的氧化物，如用於免疫殺菌的 H₂O₂。
          </p>
          <div style="margin-top: var(--space-4);">
            <span class="evidence-badge evidence-badge--preliminary" style="display:inline-flex;align-items:center;gap:4px;"><Fragment set:html={eviSvg('preliminary', 12, '#2563EB')} /> 初步證據</span>
          </div>
        </div>

        <!-- Feature 3 -->
        <div class="feature-card reveal reveal-delay-2">
          <div class="feature-icon" style="font-size: 28px; color: var(--color-primary-500); opacity: 0.7;">JP</div>
          <h3 class="feature-title">安全性高</h3>
          <p class="feature-desc">
            氫氣已被日本厚生勞動省認定為食品添加物（2016年），且多個人體臨床試驗顯示良好的安全性與耐受性。
          </p>
          <div style="margin-top: var(--space-4);">
            <span style="font-family: var(--font-family-mono); font-size: 11px; color: #0F766E; background: #CCFBF1; padding: 3px 8px; border-radius: 4px;">日本厚勞省認定 2016</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== LATEST POSTS ====== -->
  <section class="section" style="background: var(--color-secondary-100);">
    <div class="container">
      <div class="section-header" style="display: flex; justify-content: space-between; align-items: flex-end;">
        <div>
          <span class="section-label">最新文章</span>
          <h2 class="section-title" style="margin-bottom: var(--space-1);">科學文章</h2>
          <p class="section-desc" style="margin-bottom: 0;">每篇文章均標註科學證據等級</p>
        </div>
        <a href="/blog/" class="btn btn--secondary btn--md">全部文章 →</a>
      </div>

      <div class="cards-grid">
        {latestPosts.map((post, i) => (
          <article class={`article-card reveal${i > 0 ? ` reveal-delay-${i}` : ''}`}>
            <div class="article-card-image">
              {post.data.image ? (
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="article-card-image-placeholder">
                  <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="var(--color-primary-500)" stroke-width="1" opacity="0.3"><circle cx="14" cy="16" r="7"/><circle cx="26" cy="16" r="7"/><circle cx="20" cy="28" r="9"/></svg>
                </div>
              )}
            </div>
            <div class="article-card-body">
              <div class="post-card-meta">
                <a href={`/categories/${post.data.category}/`} class="tag">{post.data.category}</a>
                {post.data.evidenceLevel && (
                  <span 
                    class={`evidence-badge evidence-badge--${evidenceBadgeClass(post.data.evidenceLevel)}`}
                    style={`display:inline-flex;align-items:center;gap:4px;background:${evidenceColors[post.data.evidenceLevel]?.bg || '#EFF6FF'};color:${evidenceColors[post.data.evidenceLevel]?.color || '#2563EB'};`}
                  >
                    <Fragment set:html={eviSvg(post.data.evidenceLevel || 'preliminary', 12, evidenceColors[post.data.evidenceLevel]?.color || '#2563EB')} />
                    {evidenceBadgeLabel(post.data.evidenceLevel)}
                  </span>
                )}
              </div>
              <h3 class="article-card-title">
                <a href={`/blog/${post.slug}/`} style="color: inherit; text-decoration: none;">
                  {post.data.title}
                </a>
              </h3>
              <p class="article-card-desc">{post.data.description}</p>
              <div class="article-card-footer">
                <time class="post-card-date" datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
                {post.data.readingTime && (
                  <span class="article-card-reading-time">{post.data.readingTime} min</span>
                )}
              </div>
            </div>
          </article>
        ))}

        {latestPosts.length === 0 && (
          <div style="grid-column: 1 / -1; text-align: center; padding: 48px; color: var(--color-secondary-400);">
            <p style="font-size: 14px; color: var(--color-secondary-400); margin-bottom: 16px;">—</p>
            <p>文章即將上線，敬請期待。</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- ====== EVIDENCE LEVEL EXPLANATION ====== -->
  <section class="section" style="background: white;">
    <div class="container">
      <div class="section-header centered">
        <span class="section-label">本站標準</span>
        <h2 class="section-title">科學證據等級系統</h2>
        <p class="section-desc">
          每篇文章都會標示科學證據等級，讓你清楚知道這個說法有多少可靠研究支持。
        </p>
      </div>

      <div class="evidence-explainer-grid">
        <div class="evidence-level-card strong reveal">
          <div class="evidence-level-icon"><Fragment set:html={eviSvg('strong', 24, '#059669')} /></div>
          <h3 class="evidence-level-title">強證據</h3>
          <p class="evidence-level-desc">
            多個隨機對照試驗（RCT）或系統性回顧支持，研究方法嚴謹，結果可重複。
          </p>
        </div>
        <div class="evidence-level-card preliminary reveal reveal-delay-1">
          <div class="evidence-level-icon"><Fragment set:html={eviSvg('preliminary', 24, '#2563EB')} /></div>
          <h3 class="evidence-level-title">初步證據</h3>
          <p class="evidence-level-desc">
            有 1-2 個 RCT 或多個觀察性研究支持，結果有希望但尚需更多大型研究確認。
          </p>
        </div>
        <div class="evidence-level-card insufficient reveal reveal-delay-2">
          <div class="evidence-level-icon"><Fragment set:html={eviSvg('insufficient', 24, '#D97706')} /></div>
          <h3 class="evidence-level-title">證據不足</h3>
          <p class="evidence-level-desc">
            現有研究以動物實驗或小樣本試驗為主，尚無足夠人體大型研究支持此說法。
          </p>
        </div>
        <div class="evidence-level-card ineffective reveal reveal-delay-3">
          <div class="evidence-level-icon"><Fragment set:html={eviSvg('ineffective', 24, '#DC2626')} /></div>
          <h3 class="evidence-level-title">無效</h3>
          <p class="evidence-level-desc">
            現有研究顯示無效，或此說法與科學共識相悖，屬於誇大宣稱或誤導性資訊。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== CTA BANNER ====== -->
  <section class="section-sm">
    <div class="container">
      <div class="cta-banner reveal">
        <h2>開始科學之旅</h2>
        <p>
          不信廣告，只信證據。瀏覽我們以科學為基礎的氫水研究整理。
        </p>
        <div style="display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap;">
          <a href="/blog/" class="btn btn--primary btn--lg">瀏覽所有文章</a>
          <a href="/about/#methodology" class="btn btn--lg" style="background: transparent; border: 1px solid rgba(255,255,255,0.4); color: white;">
            了解我們的方法論
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
