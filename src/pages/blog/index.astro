---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Group by category for sidebar stats
const categories = [...new Set(posts.map(p => p.data.category))];
---

<BaseLayout title="研究文章" description="H2 Water Lab 所有氫水科學研究文章，每篇均附論文出處與證據等級評分">
  <!-- Page Hero -->
  <div style="background: linear-gradient(135deg, #F1F5F9 0%, #E0F2FE 60%, #FAFBFC 100%); padding: 60px 0 40px; border-bottom: 1px solid var(--color-silver);">
    <div class="max-w-6xl mx-auto px-6">
      <nav style="font-size: 0.8rem; color: var(--color-slate); margin-bottom: 1rem;">
        <a href="/" style="color: var(--color-slate); text-decoration: none;">首頁</a>
        <span style="margin: 0 0.5rem; opacity: 0.4;">›</span>
        <span style="color: var(--color-aqua);">研究文章</span>
      </nav>
      <h1 style="font-family: var(--font-display); font-size: 2.25rem; font-weight: 700; color: var(--color-ink); margin-bottom: 0.5rem;">研究文章</h1>
      <p style="color: var(--color-slate); font-size: 0.95rem; font-weight: 300;">
        {posts.length} 篇文章 · 每篇均附 PubMed 論文出處 · 附證據等級評分
      </p>
    </div>
  </div>

  <!-- Content: Filters + Grid -->
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex gap-8 items-start">

      <!-- Sidebar: Category Filter -->
      <aside class="hidden lg:block w-48 flex-shrink-0">
        <div style="position: sticky; top: 80px;">
          <div style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-slate); margin-bottom: 0.75rem;">分類</div>
          <a href="/blog" class="footer-link" style="font-size: 0.85rem; padding: 0.3rem 0; display: block; color: var(--color-aqua); font-weight: 500;">
            全部（{posts.length}）
          </a>
          {categories.map(cat => (
            <a href={`/categories/${cat}`} class="footer-link" style="font-size: 0.85rem; padding: 0.3rem 0;">
              {cat}（{posts.filter(p => p.data.category === cat).length}）
            </a>
          ))}
        </div>
      </aside>

      <!-- Article Grid -->
      <div class="flex-1 min-w-0">
        {posts.length === 0 ? (
          <div style="text-align: center; padding: 6rem 0; color: var(--color-slate);">
            <p style="font-size: 2rem; margin-bottom: 0.75rem;">🔬</p>
            <p style="font-size: 1.1rem;">研究文章整理中，敬請期待…</p>
          </div>
        ) : (
          <div style="display: grid; gap: 1.5rem;">
            {posts.map((post) => (
              <a href={`/blog/${post.slug}`} class="article-card" style="text-decoration: none; display: flex; flex-direction: row; align-items: stretch;">
                <!-- Thumbnail (square on left) -->
                <div style="width: 140px; min-height: 100%; background: linear-gradient(135deg, var(--color-mist) 0%, #E0F2FE 100%); display: flex; align-items: center; justify-content: center; font-size: 2rem; flex-shrink: 0; border-radius: var(--radius-md) 0 0 var(--radius-md);">
                  🧪
                </div>
                <!-- Body -->
                <div class="article-card-body" style="border-radius: 0 var(--radius-md) var(--radius-md) 0;">
                  <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.625rem; flex-wrap: wrap;">
                    <span class="tag tag-mint" style="font-size: 0.7rem;">{post.data.category}</span>
                    <span style="font-size: 0.75rem; color: var(--color-slate);">
                      {post.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </span>
                  </div>
                  <h2 style="font-size: 1rem; font-weight: 700; color: var(--color-ink); line-height: 1.5; margin-bottom: 0.5rem;">
                    {post.data.title}
                  </h2>
                  <p style="font-size: 0.85rem; color: var(--color-slate); line-height: 1.6; margin-bottom: 0.75rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                    {post.data.description}
                  </p>
                  <!-- Tags -->
                  <div style="display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: auto;">
                    {post.data.tags.slice(0, 3).map((t: string) => (
                      <span class="tag tag-slate" style="font-size: 0.68rem;">#{t}</span>
                    ))}
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>
