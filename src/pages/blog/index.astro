---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Category map
const categoryMap: Record<string, number> = {};
posts.forEach(p => {
  if (p.data.category) {
    categoryMap[p.data.category] = (categoryMap[p.data.category] || 0) + 1;
  }
});
const tabs = [
  { name: '全部', count: posts.length },
  ...Object.entries(categoryMap).map(([name, count]) => ({ name, count })),
];

function formatDate(date: Date) {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${y}.${m}.${d}`;
}

const evidenceConfig: Record<string, { label: string; color: string; bg: string }> = {
  strong:      { label: '強證據',  color: '#059669', bg: '#ECFDF5' },
  preliminary: { label: '初步證據', color: '#2563EB', bg: '#EFF6FF' },
  insufficient:{ label: '證據不足', color: '#D97706', bg: '#FFFBEB' },
  ineffective: { label: '無效',    color: '#DC2626', bg: '#FEF2F2' },
};

const evidenceLevels = [
  { key: 'strong',      label: '強證據',  desc: '多個 RCT 支持',    color: '#059669', bg: '#ECFDF5' },
  { key: 'preliminary', label: '初步證據', desc: '小型試驗 / 動物實驗', color: '#2563EB', bg: '#EFF6FF' },
  { key: 'insufficient',label: '證據不足', desc: '個案 / 體外實驗',   color: '#D97706', bg: '#FFFBEB' },
  { key: 'ineffective', label: '無效',    desc: '已被研究否定',      color: '#DC2626', bg: '#FEF2F2' },
];

// SVG helpers
function eviSvg(key: string, size = 13, color = 'currentColor') {
  const svgs: Record<string, string> = {
    strong: `<svg width="${size}" height="${size}" viewBox="0 0 14 14" fill="none" stroke="${color}" stroke-width="1.3" stroke-linecap="square" aria-hidden="true"><circle cx="7" cy="7" r="5.5"/><circle cx="7" cy="7" r="2" fill="${color}" stroke="none"/></svg>`,
    preliminary: `<svg width="${size}" height="${size}" viewBox="0 0 14 14" fill="none" stroke="${color}" stroke-width="1.3" stroke-linecap="square" aria-hidden="true"><circle cx="7" cy="7" r="5.5"/><path d="M7 1.5 A5.5 5.5 0 0 0 7 12.5 Z" fill="${color}" stroke="none"/></svg>`,
    insufficient: `<svg width="${size}" height="${size}" viewBox="0 0 14 14" fill="none" stroke="${color}" stroke-width="1.3" stroke-linecap="square" aria-hidden="true"><path d="M9.5 2.2 A5.5 5.5 0 1 1 4.5 2.2"/></svg>`,
    ineffective: `<svg width="${size}" height="${size}" viewBox="0 0 14 14" fill="none" stroke="${color}" stroke-width="1.3" stroke-linecap="square" aria-hidden="true"><circle cx="7" cy="7" r="5.5"/><line x1="3.5" y1="3.5" x2="10.5" y2="10.5"/></svg>`,
  };
  return svgs[key] ?? '';
}

function eviSvgSidebar(key: string, color: string) {
  return eviSvg(key, 12, color);
}

const moleculeSvg = `<svg width="56" height="56" viewBox="0 0 40 40" fill="none" stroke="var(--color-primary-500)" stroke-width="1" opacity="0.25" aria-hidden="true"><circle cx="14" cy="16" r="7"/><circle cx="26" cy="16" r="7"/><circle cx="20" cy="28" r="9"/></svg>`;

const arrowSvg = `<svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="square" aria-hidden="true"><line x1="2" y1="8" x2="13" y2="8"/><polyline points="9 4 13 8 9 12"/></svg>`;
---

<BaseLayout
  title="H₂ Water Lab 氫水科學研究室 — 用科學，重新認識水"
  description="H₂ Water Lab 以嚴謹的科學態度評估氫水研究，提供台灣讀者正確、可驗證的健康資訊。每篇文章標註科學證據等級。"
>
  <div class="v4-home-wrap">
    <!-- ── Hero ── -->
    <header class="v4-home-hero v4-fade">
      <div class="v4-home-hero-label">科學文章</div>
      <h1>氫水科學文章庫</h1>
      <p>每篇文章均標示科學證據等級，讓你一眼辨識研究可靠性。</p>
    </header>

    <!-- ── Main grid ── -->
    <div class="v4-main-layout">

      <!-- ── LEFT: Tabs + Cards ── -->
      <div>
        <!-- Tabs -->
        <div class="v4-tabs" role="tablist" aria-label="文章分類">
          {tabs.map(tab => (
            <button
              class={`v4-tab${tab.name === '全部' ? ' active' : ''}`}
              role="tab"
              aria-selected={tab.name === '全部' ? 'true' : 'false'}
              data-tab={tab.name}
            >
              {tab.name}
            </button>
          ))}
        </div>

        <!-- Cards -->
        <div class="v4-cards-list" id="v4-cards-list">
          {posts.map((post, idx) => {
            const evi = post.data.evidenceLevel ? evidenceConfig[post.data.evidenceLevel] : null;
            return (
              <article
                class={`v4-card v4-fade v4-fade-${Math.min(idx + 1, 3)}`}
                data-category={post.data.category}
                data-visible="true"
              >
                <!-- Thumbnail -->
                <div class="v4-card-thumb">
                  <Fragment set:html={moleculeSvg} />
                  {post.data.readingTime && (
                    <span class="v4-card-papers">引用 {post.data.readingTime} min</span>
                  )}
                </div>

                <!-- Content -->
                <div class="v4-card-body">
                  <div class="v4-card-meta">
                    <span class="v4-cat-badge">{post.data.category}</span>
                    {evi && post.data.evidenceLevel && (
                      <span
                        class="v4-evi-badge"
                        style={`background:${evi.bg};color:${evi.color}`}
                      >
                        <Fragment set:html={eviSvg(post.data.evidenceLevel, 13, evi.color)} />
                        {evi.label}
                      </span>
                    )}
                  </div>

                  <h2 class="v4-card-title">
                    <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                  </h2>

                  <p class="v4-card-excerpt">{post.data.description}</p>

                  <div class="v4-card-footer">
                    <div class="v4-card-date-row">
                      <span>{formatDate(post.data.pubDate)}</span>
                      {post.data.readingTime && (
                        <>
                          <span class="v4-sep">|</span>
                          <span>{post.data.readingTime} min</span>
                        </>
                      )}
                    </div>
                    <a href={`/blog/${post.slug}/`} class="v4-card-link" tabindex="-1" aria-hidden="true">
                      閱讀
                      <Fragment set:html={arrowSvg} />
                    </a>
                  </div>
                </div>
              </article>
            );
          })}

          {posts.length === 0 && (
            <div style="text-align:center;padding:80px 40px;color:var(--color-secondary-500);background:#fff;border-radius:6px;border:1px solid var(--color-secondary-200);">
              <p>文章即將上線，敬請期待。</p>
            </div>
          )}
        </div>
      </div>

      <!-- ── RIGHT: Sidebar ── -->
      <aside class="v4-sidebar v4-fade v4-fade-3">
        <!-- Categories -->
        <div class="v4-sidebar-widget">
          <div class="v4-sidebar-title">文章分類</div>
          {tabs.filter(t => t.name !== '全部').map(tab => (
            <button
              class="v4-sidebar-cat-btn"
              data-cat-btn={tab.name}
            >
              <span>{tab.name}</span>
              <span class="v4-sidebar-cat-count">{tab.count}</span>
            </button>
          ))}
        </div>

        <!-- Evidence Guide -->
        <div class="v4-sidebar-widget">
          <div class="v4-sidebar-title">證據等級</div>
          <div class="v4-sidebar-evi-wrap">
            {evidenceLevels.map(ev => (
              <div class="v4-sidebar-evi-row">
                <span
                  class="v4-sidebar-evi-badge"
                  style={`background:${ev.bg};color:${ev.color}`}
                >
                  <Fragment set:html={eviSvgSidebar(ev.key, ev.color)} />
                  {ev.label}
                </span>
                <span class="v4-sidebar-evi-desc">{ev.desc}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Newsletter -->
        <div class="v4-newsletter-widget">
          <div class="v4-newsletter-title">每月科學摘要</div>
          <div class="v4-newsletter-desc">只有研究，沒有推銷。</div>
          <form class="v4-newsletter-form" action="#" onsubmit="return false;">
            <input
              type="email"
              placeholder="email"
              class="v4-newsletter-input"
              aria-label="電子郵件地址"
            />
            <button type="submit" class="v4-newsletter-btn">訂閱</button>
          </form>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<script>
  // Tab filtering
  const tabs = document.querySelectorAll<HTMLButtonElement>('.v4-tab');
  const cards = document.querySelectorAll<HTMLElement>('.v4-card');
  const catBtns = document.querySelectorAll<HTMLButtonElement>('.v4-sidebar-cat-btn');

  function setTab(tabName: string) {
    // Update tab active states
    tabs.forEach(t => {
      const isActive = t.dataset.tab === tabName;
      t.classList.toggle('active', isActive);
      t.setAttribute('aria-selected', String(isActive));
    });
    // Update sidebar cat button active states
    catBtns.forEach(b => {
      b.classList.toggle('active', b.dataset.catBtn === tabName);
    });
    // Filter cards
    cards.forEach(card => {
      const cat = card.dataset.category ?? '';
      const show = tabName === '全部' || cat === tabName;
      card.style.display = show ? '' : 'none';
    });
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => setTab(tab.dataset.tab ?? '全部'));
  });

  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const name = btn.dataset.catBtn ?? '';
      // Toggle: click active → go back to 全部
      const currentActive = document.querySelector<HTMLButtonElement>('.v4-tab.active')?.dataset.tab;
      setTab(currentActive === name ? '全部' : name);
    });
  });
</script>
