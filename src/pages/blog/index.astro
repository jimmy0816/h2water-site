---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Get all unique categories
const categories = [...new Set(posts.map(p => p.data.category))].filter(Boolean);

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-TW', { year: 'numeric', month: 'short', day: 'numeric' });
}

function evidenceBadgeClass(level?: string) {
  const map: Record<string, string> = {
    strong: 'strong', preliminary: 'preliminary',
    insufficient: 'insufficient', ineffective: 'ineffective',
  };
  return level ? map[level] ?? 'preliminary' : '';
}

function evidenceBadgeLabel(level?: string) {
  const map: Record<string, string> = {
    strong: '✅ 強證據', preliminary: '🔬 初步證據',
    insufficient: '⚠️ 證據不足', ineffective: '❌ 無效/誤導',
  };
  return level ? map[level] : '';
}
---

<BaseLayout
  title="科學文章 — H₂ Water Lab"
  description="所有氫水科學文章，每篇均標示科學證據等級。氫水科學、研究文獻、健康應用、產品評測。"
>
  <div style="background: linear-gradient(180deg, var(--color-mist) 0%, var(--color-snow) 100%); padding: var(--space-5xl) 0 var(--space-3xl);">
    <div class="container">
      <div style="max-width: 600px;">
        <p style="font-family: var(--font-mono); font-size: 12px; color: var(--color-aqua); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 12px;">科學文章</p>
        <h1 style="font-family: var(--font-display); font-size: clamp(28px, 4vw, 42px); font-weight: 700; color: var(--color-ink); margin-bottom: 16px; letter-spacing: -0.02em;">
          氫水科學文章庫
        </h1>
        <p style="font-size: 16px; color: var(--color-slate); line-height: 1.7;">
          每篇文章均標示科學證據等級，讓你一眼辨識研究可靠性。
        </p>
      </div>
    </div>
  </div>

  <section class="section-sm">
    <div class="container">
      <div class="blog-layout">
        <!-- Main Content -->
        <div>
          <!-- Filter tags row (mobile visible) -->
          {categories.length > 0 && (
            <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: var(--space-2xl);">
              <a href="/blog/" class="tag" style="background: var(--color-aqua); color: white;">全部</a>
              {categories.map(cat => (
                <a href={`/categories/${cat}/`} class="tag">{cat}</a>
              ))}
            </div>
          )}

          <!-- Posts List -->
          <div class="posts-list">
            {posts.map(post => (
              <article class="post-list-item reveal">
                <div class="post-list-image">
                  {post.data.image ? (
                    <img src={post.data.image} alt={post.data.title} loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;" />
                  ) : (
                    <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#E0F2FE,#DBEAFE);">
                      <span style="font-size:36px;opacity:0.5;">💧</span>
                    </div>
                  )}
                </div>
                <div class="post-list-body">
                  <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px; flex-wrap: wrap;">
                    <a href={`/categories/${post.data.category}/`} class="tag">{post.data.category}</a>
                    {post.data.evidenceLevel && (
                      <span class={`evidence-badge ${evidenceBadgeClass(post.data.evidenceLevel)}`}>
                        {evidenceBadgeLabel(post.data.evidenceLevel)}
                      </span>
                    )}
                  </div>
                  <h2 style="font-size: 18px; font-weight: 700; color: var(--color-ink); margin-bottom: 8px; line-height: 1.4;">
                    <a href={`/blog/${post.slug}/`} style="color: inherit; text-decoration: none; transition: color 0.15s;"
                       onmouseover="this.style.color='var(--color-aqua)'"
                       onmouseout="this.style.color='inherit'">
                      {post.data.title}
                    </a>
                  </h2>
                  <p style="font-size: 14px; color: var(--color-slate); line-height: 1.65; margin-bottom: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                    {post.data.description}
                  </p>
                  <div style="display: flex; align-items: center; gap: 16px; font-size: 13px; color: var(--color-slate);">
                    <time datetime={post.data.pubDate.toISOString()} style="font-family: var(--font-mono);">
                      {formatDate(post.data.pubDate)}
                    </time>
                    {post.data.readingTime && (
                      <span>📖 {post.data.readingTime} 分鐘</span>
                    )}
                    <a href={`/blog/${post.slug}/`} style="margin-left: auto; color: var(--color-aqua); font-weight: 500; font-size: 13px;">
                      閱讀 →
                    </a>
                  </div>
                </div>
              </article>
            ))}

            {posts.length === 0 && (
              <div style="text-align: center; padding: 80px 40px; color: var(--color-slate); background: white; border-radius: var(--radius-md); border: 1px solid var(--color-silver);">
                <p style="font-size: 48px; margin-bottom: 16px;">📝</p>
                <p style="font-size: 18px; font-weight: 600; color: var(--color-graphite); margin-bottom: 8px;">文章即將上線</p>
                <p>我們正在整理科學文章，敬請期待。</p>
              </div>
            )}
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="blog-sidebar">
          <!-- Categories -->
          <div class="sidebar-widget">
            <div class="sidebar-widget-title">文章分類</div>
            <ul class="sidebar-category-list">
              {categories.map(cat => {
                const count = posts.filter(p => p.data.category === cat).length;
                return (
                  <li>
                    <a href={`/categories/${cat}/`}>
                      <span>{cat}</span>
                      <span style="font-family: var(--font-mono); font-size: 12px; background: var(--color-mist); padding: 2px 7px; border-radius: 9999px;">{count}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>

          <!-- Evidence Guide -->
          <div class="sidebar-widget">
            <div class="sidebar-widget-title">證據等級說明</div>
            <div style="display: flex; flex-direction: column; gap: 10px;">
              {[
                { cls: 'strong', label: '✅ 強證據', desc: '多個 RCT 支持' },
                { cls: 'preliminary', label: '🔬 初步證據', desc: '初步 RCT，待確認' },
                { cls: 'insufficient', label: '⚠️ 證據不足', desc: '動物或小樣本為主' },
                { cls: 'ineffective', label: '❌ 無效/誤導', desc: '研究顯示無效' },
              ].map(item => (
                <div style="display: flex; flex-direction: column; gap: 4px;">
                  <span class={`evidence-badge ${item.cls}`} style="width: fit-content;">{item.label}</span>
                  <span style="font-size: 12px; color: var(--color-slate); padding-left: 2px;">{item.desc}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- About mini -->
          <div class="sidebar-widget" style="background: linear-gradient(135deg, var(--color-aqua-dark), var(--color-aqua)); color: white; border: none;">
            <div style="font-size: 13px; font-weight: 700; margin-bottom: 8px; color: white;">關於本站</div>
            <p style="font-size: 13px; color: rgba(255,255,255,0.8); line-height: 1.6; margin-bottom: 12px;">
              H₂ Water Lab 以科學為本，不信廣告，只信證據。
            </p>
            <a href="/about/" style="font-size: 13px; color: white; font-weight: 500; text-decoration: underline;">了解我們的方法論 →</a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
