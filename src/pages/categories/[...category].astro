---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map(p => p.data.category))].filter(Boolean);

  return categories.map(category => ({
    params: { category },
    props: {
      category,
      posts: posts
        .filter(p => p.data.category === category)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { category, posts } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-TW', { year: 'numeric', month: 'short', day: 'numeric' });
}

function evidenceBadgeClass(level?: string) {
  const map: Record<string, string> = {
    strong: 'strong', preliminary: 'preliminary',
    insufficient: 'insufficient', ineffective: 'ineffective',
  };
  return level ? map[level] ?? 'preliminary' : '';
}

function evidenceBadgeLabel(level?: string) {
  const map: Record<string, string> = {
    strong: '✅ 強證據', preliminary: '🔬 初步證據',
    insufficient: '⚠️ 證據不足', ineffective: '❌ 無效/誤導',
  };
  return level ? map[level] : '';
}
---

<BaseLayout
  title={`${category} — H₂ Water Lab`}
  description={`H₂ Water Lab 氫水科學研究室 — ${category} 分類下的所有文章，每篇均標示科學證據等級。`}
>
  <!-- Category Header -->
  <div style="background: linear-gradient(135deg, #F1F5F9 0%, #E0F2FE 50%, #FAFBFC 100%); padding: var(--space-5xl) 0 var(--space-3xl);">
    <div class="container">
      <nav class="breadcrumb" aria-label="麵包屑">
        <a href="/">首頁</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/blog/">科學文章</a>
        <span class="breadcrumb-sep">/</span>
        <span style="color: var(--color-graphite);">{category}</span>
      </nav>
      <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 12px;">
        <a href={`/categories/${category}/`} class="tag" style="background: var(--color-aqua); color: white; font-size: 13px;">{category}</a>
        <span style="font-family: var(--font-mono); font-size: 13px; color: var(--color-slate);">{posts.length} 篇文章</span>
      </div>
      <h1 style="font-family: var(--font-display); font-size: clamp(28px, 4vw, 42px); font-weight: 700; color: var(--color-ink); letter-spacing: -0.02em;">
        {category}
      </h1>
    </div>
  </div>

  <section class="section-sm">
    <div class="container">
      <div class="posts-list">
        {posts.map(post => (
          <article class="post-list-item reveal">
            <div class="post-list-image">
              {post.data.image ? (
                <img src={post.data.image} alt={post.data.title} loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;" />
              ) : (
                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#E0F2FE,#DBEAFE);">
                  <span style="font-size:36px;opacity:0.5;">💧</span>
                </div>
              )}
            </div>
            <div class="post-list-body">
              <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px; flex-wrap: wrap;">
                <a href={`/categories/${post.data.category}/`} class="tag">{post.data.category}</a>
                {post.data.evidenceLevel && (
                  <span class={`evidence-badge evidence-badge--${evidenceBadgeClass(post.data.evidenceLevel)}`}>
                    {evidenceBadgeLabel(post.data.evidenceLevel)}
                  </span>
                )}
              </div>
              <h2 style="font-size: 18px; font-weight: 700; color: var(--color-ink); margin-bottom: 8px; line-height: 1.4;">
                <a href={`/blog/${post.slug}/`} style="color: inherit; text-decoration: none;">
                  {post.data.title}
                </a>
              </h2>
              <p style="font-size: 14px; color: var(--color-slate); line-height: 1.65; margin-bottom: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                {post.data.description}
              </p>
              <div style="display: flex; align-items: center; gap: 16px; font-size: 13px; color: var(--color-slate);">
                <time datetime={post.data.pubDate.toISOString()} style="font-family: var(--font-mono);">
                  {formatDate(post.data.pubDate)}
                </time>
                {post.data.readingTime && <span>📖 {post.data.readingTime} 分鐘</span>}
                <a href={`/blog/${post.slug}/`} style="margin-left: auto; color: var(--color-aqua); font-weight: 500;">閱讀 →</a>
              </div>
            </div>
          </article>
        ))}

        {posts.length === 0 && (
          <div style="text-align: center; padding: 80px 40px; color: var(--color-slate); background: white; border-radius: var(--radius-md); border: 1px solid var(--color-silver);">
            <p style="font-size: 48px; margin-bottom: 16px;">📝</p>
            <p>此分類尚無文章，敬請期待。</p>
          </div>
        )}
      </div>

      <div style="margin-top: var(--space-3xl);">
        <a href="/blog/" class="btn btn--secondary btn--md">← 返回所有文章</a>
      </div>
    </div>
  </section>
</BaseLayout>
