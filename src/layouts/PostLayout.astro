---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category?: string;
  tags?: string[];
  image?: string;
  author?: string;
  evidenceLevel?: 'strong' | 'preliminary' | 'insufficient' | 'ineffective';
  readingTime?: number;
  lang?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category = '氫水科學',
  tags = [],
  image,
  author = 'H₂ Water Lab',
  evidenceLevel,
  readingTime,
  lang = 'zh-TW',
} = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' });
}

const evidenceBadgeClass = {
  strong: 'strong',
  preliminary: 'preliminary',
  insufficient: 'insufficient',
  ineffective: 'ineffective',
};

// SVG icons for evidence badges (v4)
function eviSvgHtml(key: string, size = 13, color = 'currentColor') {
  const svgs: Record<string, string> = {
    strong: `<svg width="${size}" height="${size}" viewBox="0 0 14 14" fill="none" stroke="${color}" stroke-width="1.3" stroke-linecap="square" aria-hidden="true"><circle cx="7" cy="7" r="5.5"/><circle cx="7" cy="7" r="2" fill="${color}" stroke="none"/></svg>`,
    preliminary: `<svg width="${size}" height="${size}" viewBox="0 0 14 14" fill="none" stroke="${color}" stroke-width="1.3" stroke-linecap="square" aria-hidden="true"><circle cx="7" cy="7" r="5.5"/><path d="M7 1.5 A5.5 5.5 0 0 0 7 12.5 Z" fill="${color}" stroke="none"/></svg>`,
    insufficient: `<svg width="${size}" height="${size}" viewBox="0 0 14 14" fill="none" stroke="${color}" stroke-width="1.3" stroke-linecap="square" aria-hidden="true"><path d="M9.5 2.2 A5.5 5.5 0 1 1 4.5 2.2"/></svg>`,
    ineffective: `<svg width="${size}" height="${size}" viewBox="0 0 14 14" fill="none" stroke="${color}" stroke-width="1.3" stroke-linecap="square" aria-hidden="true"><circle cx="7" cy="7" r="5.5"/><line x1="3.5" y1="3.5" x2="10.5" y2="10.5"/></svg>`,
  };
  return svgs[key] ?? '';
}

const evidenceBadgeColors: Record<string, { color: string; bg: string }> = {
  strong:      { color: '#059669', bg: '#ECFDF5' },
  preliminary: { color: '#2563EB', bg: '#EFF6FF' },
  insufficient:{ color: '#D97706', bg: '#FFFBEB' },
  ineffective: { color: '#DC2626', bg: '#FEF2F2' },
};

const evidenceBadgeLabel = {
  strong: '強證據',
  preliminary: '初步證據',
  insufficient: '證據不足',
  ineffective: '無效/誤導',
};

const evidenceBadgeDesc = {
  strong: '多個嚴謹 RCT 或系統性回顧支持此結論',
  preliminary: '初步 RCT 或觀察性研究支持，尚需更多研究確認',
  insufficient: '現有研究以動物或小樣本為主，人體大型研究不足',
  ineffective: '現有研究顯示無效，或與科學共識相悖',
};
---

<BaseLayout
  title={`${title} — H₂ Water Lab`}
  description={description}
  image={image}
  type="article"
  pubDate={pubDate}
  lang={lang}
>
  <!-- Post Layout Wrapper -->
  <div style="padding-block: var(--space-12) var(--space-24);">
    <div class="post-layout">
      <!-- TOC (desktop sticky left) -->
      <aside class="post-toc" aria-label="文章目錄" id="toc-container">
        <div class="toc-heading">目錄</div>
        <nav id="toc-nav">
          <ul class="toc-list" id="toc-list">
            <!-- Populated by JS -->
          </ul>
        </nav>
      </aside>

      <!-- Article Content -->
      <article class="post-content">
        <!-- Breadcrumb -->
        <nav class="breadcrumb" aria-label="麵包屑">
          <a href="/">首頁</a>
          <span class="breadcrumb-sep">/</span>
          <a href="/blog/">科學文章</a>
          <span class="breadcrumb-sep">/</span>
          {category && <a href={`/categories/${category}/`}>{category}</a>}
        </nav>

        <!-- Post Header -->
        <header class="post-header">
          <div class="post-header-meta">
            {category && (
              <a href={`/categories/${category}/`} class="tag">{category}</a>
            )}
            {evidenceLevel && (() => {
              const ec = evidenceBadgeColors[evidenceLevel];
              return (
                <span
                  class={`evidence-badge evidence-badge--${evidenceBadgeClass[evidenceLevel]}`}
                  title={evidenceBadgeDesc[evidenceLevel]}
                  style={ec ? `background:${ec.bg};color:${ec.color};border-radius:3px` : ''}
                >
                  <Fragment set:html={eviSvgHtml(evidenceLevel, 13, ec?.color ?? 'currentColor')} />
                  {evidenceBadgeLabel[evidenceLevel]}
                </span>
              );
            })()}
            {tags.slice(0, 2).map(tag => (
              <span class="tag tag-mint">{tag}</span>
            ))}
          </div>

          <h1 class="post-title">{title}</h1>
          <p class="post-description">{description}</p>

          <div class="article-meta">
            <div style="display: flex; align-items: center; gap: 8px;">
              <div style="width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, var(--color-primary-200), var(--color-primary-500)); display: flex; align-items: center; justify-content: center;">
                <svg width="16" height="16" viewBox="0 0 40 40" fill="none" stroke="#fff" stroke-width="2" aria-hidden="true"><circle cx="14" cy="16" r="7"/><circle cx="26" cy="16" r="7"/><circle cx="20" cy="28" r="9"/></svg>
              </div>
              <span style="font-size: 14px; font-weight: 600; color: var(--color-secondary-700);">{author}</span>
            </div>
            <span class="article-meta-sep">·</span>
            <time datetime={pubDate.toISOString()} style="font-family: var(--font-family-mono); font-size: 13px; color: var(--color-secondary-400);">
              {formatDate(pubDate)}
            </time>
            {updatedDate && (
              <>
                <span class="article-meta-sep">·</span>
                <span style="font-size: 13px; color: var(--color-secondary-400);">
                  更新：<time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
                </span>
              </>
            )}
            {readingTime && (
              <>
                <span class="article-meta-sep">·</span>
                <span style="font-family: var(--font-family-mono); font-size: 13px; color: var(--color-secondary-500);">
                  {readingTime} 分鐘
                </span>
              </>
            )}
          </div>
        </header>

        <!-- Article Body -->
        <div class="prose" id="article-body">
          <slot />
        </div>

        <!-- Post Footer -->
        <footer class="post-footer">
          <!-- Disclaimer -->
          <div class="citation-card" style="margin-bottom: var(--space-8);">
            <div class="citation-journal">免責聲明</div>
            <p class="citation-conclusion">
              ⚠️ 本文內容僅供科普資訊參考，不構成醫療建議、診斷或治療方案。文中提及的研究結果僅代表特定研究的發現，
              不代表普遍適用性。健康問題請諮詢有執照的醫療專業人員。
            </p>
          </div>

          <!-- Feedback -->
          <div class="post-feedback">
            <p>這篇文章對你有幫助嗎？</p>
            <div class="feedback-buttons">
              <button class="feedback-btn" data-feedback="helpful">
                👍 有幫助
              </button>
              <button class="feedback-btn" data-feedback="not-helpful">
                👎 需要改進
              </button>
            </div>
          </div>

          <!-- Tags -->
          {tags.length > 0 && (
            <div style="margin-bottom: var(--space-8);">
              <div style="font-size: 13px; color: var(--color-secondary-400); margin-bottom: 10px;">相關標籤：</div>
              <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                {tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          )}

          <!-- Related Articles placeholder -->
          <div>
            <h2 style="font-size: 20px; font-weight: 700; color: var(--color-secondary-800); margin-bottom: var(--space-6);">繼續閱讀</h2>
            <a href="/blog/" class="btn btn--secondary btn--md">← 返回所有文章</a>
          </div>
        </footer>
      </article>
    </div>
  </div>
</BaseLayout>

<script>
  // Auto-generate TOC from h2/h3 in article body
  function buildTOC() {
    const article = document.getElementById('article-body');
    const tocList = document.getElementById('toc-list');
    if (!article || !tocList) return;

    const headings = article.querySelectorAll('h2, h3');
    if (headings.length < 2) {
      const tocContainer = document.getElementById('toc-container');
      if (tocContainer) tocContainer.style.display = 'none';
      return;
    }

    const items: string[] = [];
    headings.forEach((heading, index) => {
      const id = heading.id || `heading-${index}`;
      if (!heading.id) heading.id = id;
      const isH3 = heading.tagName === 'H3';
      items.push(
        `<li class="${isH3 ? 'toc-h3' : ''}">
          <a href="#${id}" class="toc-link">${heading.textContent}</a>
        </li>`
      );
    });

    tocList.innerHTML = items.join('');
  }

  // Highlight active TOC item on scroll
  function initTOCHighlight() {
    const tocLinks = document.querySelectorAll('.toc-link');
    if (!tocLinks.length) return;

    const headingEls = Array.from(
      document.querySelectorAll('#article-body h2, #article-body h3')
    ) as HTMLElement[];

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tocLinks.forEach(link => link.classList.remove('active'));
            const activeLink = document.querySelector(`.toc-link[href="#${entry.target.id}"]`);
            activeLink?.classList.add('active');
          }
        });
      },
      {
        rootMargin: `-${64 + 20}px 0px -70% 0px`,
        threshold: 0,
      }
    );

    headingEls.forEach(el => observer.observe(el));
  }

  // Feedback buttons
  function initFeedback() {
    document.querySelectorAll('.feedback-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const value = (btn as HTMLElement).dataset.feedback;
        document.querySelectorAll('.feedback-btn').forEach(b => {
          b.classList.remove('active');
          (b as HTMLElement).style.borderColor = '';
          (b as HTMLElement).style.color = '';
        });
        (btn as HTMLElement).style.borderColor = 'var(--color-aqua)';
        (btn as HTMLElement).style.color = 'var(--color-aqua)';
        (btn as HTMLElement).style.fontWeight = '600';
      });
    });
  }

  // Replace emoji evidence markers with SVG icons (v4 — no emoji anywhere)
  function replaceEmojiWithBadges() {
    const article = document.getElementById('article-body');
    if (!article) return;

    // SVG icon builders
    function eviSvg(key: string, size = 13, color = 'currentColor') {
      const svgs: Record<string, string> = {
        strong: `<svg width="${size}" height="${size}" viewBox="0 0 14 14" fill="none" stroke="${color}" stroke-width="1.3" stroke-linecap="square" aria-hidden="true"><circle cx="7" cy="7" r="5.5"/><circle cx="7" cy="7" r="2" fill="${color}" stroke="none"/></svg>`,
        preliminary: `<svg width="${size}" height="${size}" viewBox="0 0 14 14" fill="none" stroke="${color}" stroke-width="1.3" stroke-linecap="square" aria-hidden="true"><circle cx="7" cy="7" r="5.5"/><path d="M7 1.5 A5.5 5.5 0 0 0 7 12.5 Z" fill="${color}" stroke="none"/></svg>`,
        insufficient: `<svg width="${size}" height="${size}" viewBox="0 0 14 14" fill="none" stroke="${color}" stroke-width="1.3" stroke-linecap="square" aria-hidden="true"><path d="M9.5 2.2 A5.5 5.5 0 1 1 4.5 2.2"/></svg>`,
        ineffective: `<svg width="${size}" height="${size}" viewBox="0 0 14 14" fill="none" stroke="${color}" stroke-width="1.3" stroke-linecap="square" aria-hidden="true"><circle cx="7" cy="7" r="5.5"/><line x1="3.5" y1="3.5" x2="10.5" y2="10.5"/></svg>`,
      };
      return svgs[key] ?? '';
    }

    const colors: Record<string, string> = {
      strong: '#059669', preliminary: '#2563EB',
      insufficient: '#D97706', ineffective: '#DC2626',
    };

    const replacements: [string, string, string][] = [
      ['✅', 'strong', '強證據'],
      ['🔬', 'preliminary', '初步證據'],
      ['⚠️', 'insufficient', '注意'],
      ['❌', 'ineffective', '不建議'],
    ];

    const walker = document.createTreeWalker(article, NodeFilter.SHOW_TEXT);
    const textNodes: Text[] = [];
    let node: Text | null;
    while ((node = walker.nextNode() as Text)) {
      for (const [emoji] of replacements) {
        if (node.textContent?.includes(emoji)) {
          textNodes.push(node);
          break;
        }
      }
    }

    textNodes.forEach(textNode => {
      const parent = textNode.parentNode;
      if (!parent) return;
      let html = textNode.textContent || '';
      for (const [emoji, level, label] of replacements) {
        // In headings, just strip the emoji
        if (parent instanceof HTMLHeadingElement) {
          html = html.replaceAll(emoji, '').trim();
          continue;
        }
        // Replace with inline SVG icon
        const color = colors[level] ?? 'currentColor';
        const svgIcon = `<span class="evidence-svg-inline" style="display:inline-flex;align-items:center;vertical-align:middle;margin-right:3px;" aria-label="${label}">${eviSvg(level, 13, color)}</span>`;
        html = html.replaceAll(emoji + ' ', svgIcon);
        html = html.replaceAll(emoji, svgIcon);
      }
      const template = document.createElement('template');
      template.innerHTML = html;
      parent.replaceChild(template.content, textNode);
    });
  }

  buildTOC();
  initTOCHighlight();
  initFeedback();
  replaceEmojiWithBadges();
</script>
