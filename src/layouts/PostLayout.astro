---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  author: string;
  image?: string;
  lang?: string;
}

const { title, description, pubDate, updatedDate, category, tags, author, image, lang = 'zh' } = Astro.props;

const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Person', name: author },
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  publisher: {
    '@type': 'Organization',
    name: 'H2 Water Lab',
    url: 'https://h2water.co',
  },
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={Astro.url.href}
  ogImage={image}
  lang={lang}
  article={{
    publishedTime: pubDate.toISOString(),
    modifiedTime: (updatedDate ?? pubDate).toISOString(),
    author,
    tags,
  }}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdArticle)} slot="head" />

  <article class="prose max-w-none">
    <!-- Breadcrumb -->
    <nav class="text-sm mb-6" style="color: #0EA5E9;">
      <a href="/" style="color: #0EA5E9;">首頁</a>
      <span class="mx-2">/</span>
      <a href="/blog" style="color: #0EA5E9;">文章</a>
      <span class="mx-2">/</span>
      <span style="color: #0369A1;">{title}</span>
    </nav>

    <!-- Header -->
    <header class="mb-8">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-xs px-2 py-1 rounded" style="background-color: #EFF6FF; color: #0EA5E9;">{category}</span>
        {tags.map(tag => (
          <span class="text-xs px-2 py-1 rounded" style="background-color: #DBEAFE; color: #0369A1;">#{tag}</span>
        ))}
      </div>
      <h1 style="color: #0369A1; font-size: 2rem; font-weight: 700; line-height: 1.3;">{title}</h1>
      <p class="mt-3" style="color: #0EA5E9; font-size: 0.95rem;">
        {author} · {pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
        {updatedDate && ` · 更新：${updatedDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}`}
      </p>
    </header>

    <!-- Content -->
    <div style="line-height: 1.9; font-size: 1.05rem;">
      <slot />
    </div>
  </article>
</BaseLayout>
