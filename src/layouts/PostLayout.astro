---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  author: string;
  image?: string;
  lang?: string;
  evidenceLevel?: 'strong' | 'preliminary' | 'insufficient' | 'ineffective';
  readingTime?: number;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags,
  author,
  image,
  lang = 'zh',
  evidenceLevel,
  readingTime,
} = Astro.props;

const evidenceMap = {
  strong:      { emoji: '✅', label: '強證據',   class: 'strong' },
  preliminary: { emoji: '🔬', label: '初步證據', class: 'preliminary' },
  insufficient:{ emoji: '⚠️', label: '證據不足', class: 'insufficient' },
  ineffective: { emoji: '❌', label: '無效',     class: 'ineffective' },
};

const badge = evidenceLevel ? evidenceMap[evidenceLevel] : null;

const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Organization', name: author },
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  publisher: {
    '@type': 'Organization',
    name: 'H2 Water Lab',
    url: 'https://h2water.co',
  },
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={Astro.url.href}
  ogImage={image}
  lang={lang}
  article={{
    publishedTime: pubDate.toISOString(),
    modifiedTime: (updatedDate ?? pubDate).toISOString(),
    author,
    tags,
  }}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdArticle)} slot="head" />

  <!-- ===== ARTICLE HERO ===== -->
  <section class="hero-section inner-page" style="min-height: 50vh;">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <!-- Breadcrumb -->
      <nav style="font-size: 0.8rem; color: var(--color-slate); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
        <a href="/" style="color: var(--color-slate); text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color='var(--color-aqua)'" onmouseout="this.style.color='var(--color-slate)'">首頁</a>
        <span style="opacity: 0.4;">›</span>
        <a href="/blog" style="color: var(--color-slate); text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color='var(--color-aqua)'" onmouseout="this.style.color='var(--color-slate)'">文章</a>
        <span style="opacity: 0.4;">›</span>
        <span style="color: var(--color-aqua);">{category}</span>
      </nav>

      <!-- Tags -->
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem;">
        <a href={`/categories/${category}`} class="tag tag-aqua">{category}</a>
        {tags.map(t => <span class="tag tag-slate">#{t}</span>)}
      </div>

      <!-- Title -->
      <h1 style="font-family: var(--font-display); font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight: 700; color: var(--color-ink); line-height: 1.3; max-width: 800px; margin-bottom: 1.25rem;">
        {title}
      </h1>

      <!-- Meta Row -->
      <div class="post-meta">
        {badge && (
          <span class={`evidence-badge ${badge.class}`}>
            {badge.emoji} {badge.label}
          </span>
        )}
        <span class="post-meta-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          {pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
        </span>
        {updatedDate && (
          <span class="post-meta-item" style="color: var(--color-aqua);">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
            更新 {updatedDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
        )}
        {readingTime && (
          <span class="post-meta-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            約 {readingTime} 分鐘
          </span>
        )}
        <span class="post-meta-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          {author}
        </span>
      </div>
    </div>
  </section>

  <!-- ===== ARTICLE BODY: TOC + CONTENT ===== -->
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex gap-10 items-start">

      <!-- Sticky TOC (Desktop only) -->
      <aside class="hidden lg:block w-56 flex-shrink-0">
        <div class="toc-sidebar" id="toc">
          <div class="toc-title">目錄</div>
          <div id="toc-links">
            <!-- Populated by JS -->
          </div>
        </div>
      </aside>

      <!-- Article Content -->
      <article class="flex-1 min-w-0">
        <div class="prose-article" id="article-content">
          <slot />
        </div>

        <!-- ===== FEEDBACK ===== -->
        <div style="margin-top: 4rem; padding: 2rem; background: var(--color-mist); border-radius: var(--radius-md); border: 1px solid var(--color-silver); text-align: center;">
          <p style="font-size: 1rem; font-weight: 500; color: var(--color-ink); margin-bottom: 1rem;">這篇文章有幫助嗎？</p>
          <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
            <button class="btn btn-primary" style="font-size: 0.85rem; padding: 8px 20px;">👍 有幫助</button>
            <button class="btn btn-secondary" style="font-size: 0.85rem; padding: 8px 20px;">💬 有疑問</button>
          </div>
          <p style="font-size: 0.8rem; color: var(--color-slate); margin-top: 1rem;">
            你的回饋幫助我們持續改善內容品質
          </p>
        </div>

        <!-- ===== Related Articles ===== -->
        <div style="margin-top: 3rem;">
          <h3 style="font-size: 1.125rem; font-weight: 700; color: var(--color-ink); margin-bottom: 1.5rem; padding-bottom: 0.5rem; border-bottom: 2px solid var(--color-mist);">相關文章</h3>
          <div style="text-align: center; padding: 2rem; color: var(--color-slate);">
            <a href="/blog" class="btn btn-secondary">瀏覽更多研究文章 →</a>
          </div>
        </div>
      </article>
    </div>
  </div>

  <!-- TOC Script -->
  <script>
    // Build TOC from article headings
    const article = document.getElementById('article-content');
    const tocLinks = document.getElementById('toc-links');

    if (article && tocLinks) {
      const headings = article.querySelectorAll('h2, h3');
      headings.forEach((h, idx) => {
        const id = h.id || `heading-${idx}`;
        if (!h.id) h.id = id;

        const link = document.createElement('a');
        link.href = `#${id}`;
        link.className = 'toc-link';
        link.textContent = h.textContent || '';
        if (h.tagName === 'H3') {
          link.style.paddingLeft = '1.5rem';
          link.style.fontSize = '0.77rem';
        }
        tocLinks.appendChild(link);
      });

      // Intersection observer for active state
      const allLinks = tocLinks.querySelectorAll('.toc-link');
      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            allLinks.forEach(l => l.classList.remove('active'));
            const active = tocLinks.querySelector(`a[href="#${entry.target.id}"]`);
            active?.classList.add('active');
          }
        });
      }, { rootMargin: '-80px 0px -70% 0px' });

      headings.forEach(h => observer.observe(h));
    }
  </script>
</BaseLayout>
