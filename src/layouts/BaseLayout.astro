---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  lang?: string;
}

const {
  title,
  description = 'H₂ Water Lab 氫水科學研究室 — 以嚴謹的科學態度評估氫水相關研究，提供台灣讀者正確可驗證的健康資訊。',
  image = '/og-default.png',
  type = 'website',
  pubDate,
  lang = 'zh-TW',
} = Astro.props;

const siteName = 'H₂ Water Lab 氫水科學研究室';
const siteUrl = 'https://h2water.co';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': type === 'article' ? 'MedicalWebPage' : 'WebSite',
  name: title,
  description,
  url: canonicalUrl,
  publisher: {
    '@type': 'Organization',
    name: siteName,
    url: siteUrl,
  },
  ...(pubDate && { datePublished: pubDate.toISOString() }),
};

const navLinks = [
  { href: '/blog/', label: '科學文章' },
  { href: '/categories/', label: '分類' },
  { href: '/about/', label: '關於' },
];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0891B2" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={new URL(image, siteUrl).toString()} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="zh_TW" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, siteUrl).toString()} />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;700&family=Noto+Sans+TC:wght@300;400;500;700&family=JetBrains+Mono&display=swap"
    rel="stylesheet"
  />

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- GA4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-51RRQ7DSEB" is:inline></script>
  <Fragment set:html={`<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-51RRQ7DSEB');</script>`} />
</head>
<body>
  <!-- Skip Nav -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 btn btn-primary">
    跳到主要內容
  </a>

  <!-- Navigation -->
  <header class="site-header" id="site-header">
    <div class="container">
      <a href="/" class="site-logo" aria-label="H₂ Water Lab 首頁">
        <span class="h2">H₂</span>
        <span class="lab">Water Lab</span>
      </a>

      <nav class="site-nav" aria-label="主要導航">
        {navLinks.map(link => (
          <a href={link.href}>{link.label}</a>
        ))}
        <a href="/blog/" class="btn btn-primary btn-sm">開始閱讀</a>
      </nav>

      <button class="nav-toggle" id="nav-toggle" aria-label="開啟選單" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </header>

  <!-- Mobile Nav Overlay -->
  <div id="mobile-nav" class="mobile-nav" aria-hidden="true">
    <nav>
      {navLinks.map(link => (
        <a href={link.href}>{link.label}</a>
      ))}
      <a href="/blog/" class="btn btn-primary" style="margin-top: 8px; justify-content: center;">開始閱讀</a>
    </nav>
  </div>

  <!-- Main -->
  <main id="main-content" tabindex="-1" style="padding-top: var(--nav-height);">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <!-- Brand -->
        <div class="footer-brand">
          <a href="/" class="site-logo" aria-label="H₂ Water Lab 首頁">
            <span class="h2">H₂</span>
            <span class="lab">Water Lab</span>
          </a>
          <p>
            氫水科學研究室 — 用嚴謹的科學態度評估氫水研究，<br />
            提供台灣讀者正確、可驗證的健康資訊。
          </p>
          <p style="margin-top: 12px; font-size: 13px; color: #475569;">
            台灣先行・預留日文 i18n
          </p>
        </div>

        <!-- Content Categories -->
        <div>
          <div class="footer-col-title">科學文章</div>
          <ul class="footer-links">
            <li><a href="/categories/hydrogen-science/">氫水科學</a></li>
            <li><a href="/categories/research-literature/">研究文獻</a></li>
            <li><a href="/categories/health-application/">健康應用</a></li>
            <li><a href="/categories/product-review/">產品評測</a></li>
            <li><a href="/categories/faq/">常見問題</a></li>
          </ul>
        </div>

        <!-- About & Legal -->
        <div>
          <div class="footer-col-title">關於本站</div>
          <ul class="footer-links">
            <li><a href="/about/">關於 H₂ Water Lab</a></li>
            <li><a href="/about/#methodology">我們的方法論</a></li>
            <li><a href="/about/#evidence">證據等級說明</a></li>
            <li><a href="/privacy/">隱私政策</a></li>
            <li><a href="/rss.xml">RSS 訂閱</a></li>
          </ul>
        </div>
      </div>

      <div class="footer-bottom">
        <p class="footer-copyright">
          © {new Date().getFullYear()} H₂ Water Lab 氫水科學研究室. All rights reserved.
        </p>
        <p class="footer-disclaimer">
          ⚠️ 本站內容僅供科普資訊參考，不構成醫療建議。健康問題請諮詢醫療專業人員。
        </p>
      </div>
    </div>
  </footer>
</body>
</html>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border-width: 0;
  }

  .mobile-nav {
    display: none;
    position: fixed;
    top: var(--nav-height);
    left: 0;
    right: 0;
    background: rgba(250, 251, 252, 0.97);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-silver);
    padding: var(--space-lg) var(--gutter) var(--space-xl);
    z-index: 90;
    box-shadow: var(--shadow-lg);
  }

  .mobile-nav.open {
    display: block;
  }

  .mobile-nav nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .mobile-nav a {
    font-size: 16px;
    font-weight: 500;
    color: var(--color-graphite);
    text-decoration: none;
    padding: var(--space-xs) 0;
    border-bottom: 1px solid var(--color-mist);
  }

  .mobile-nav a:last-of-type {
    border-bottom: none;
  }
</style>

<script>
  // Nav scroll effect
  const header = document.getElementById('site-header');
  function updateHeader() {
    if (window.scrollY > 64) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }
  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  // Mobile nav toggle
  const toggle = document.getElementById('nav-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.contains('open');
    mobileNav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Scroll reveal
  const revealEls = document.querySelectorAll('.reveal');
  if (revealEls.length && window.matchMedia('(min-width: 768px)').matches) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    revealEls.forEach(el => observer.observe(el));
  } else {
    revealEls.forEach(el => el.classList.add('visible'));
  }
</script>
