---
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  lang?: string;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
  };
}

const {
  title,
  description = 'H2 Water Lab — 氫水科學研究室，用科學數據解答你對氫水健康的每一個疑問',
  canonical = Astro.url.href,
  ogImage = '/og-default.png',
  lang = 'zh',
  article,
} = Astro.props;

const siteName = 'H2 Water Lab | 氫水科學研究室';
const siteUrl = 'https://h2water.co';

const jsonLdWebSite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: siteUrl,
  description,
  inLanguage: lang === 'en' ? 'en' : 'zh-TW',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/search?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const jsonLdOrganization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'H2 Water Lab',
  alternateName: '氫水研究室',
  url: siteUrl,
  logo: `${siteUrl}/logo.png`,
  sameAs: [],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    availableLanguage: ['Chinese', 'Japanese'],
  },
};
---

<!DOCTYPE html>
<html lang={lang === 'en' ? 'en' : 'zh-TW'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | {siteName}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:title" content={`${title} | ${siteName}`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  {article?.publishedTime && <meta property="article:published_time" content={article.publishedTime} />}
  {article?.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | ${siteName}`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

  <!-- i18n alternates (reserved) -->
  <!-- <link rel="alternate" hreflang="zh-TW" href={`${siteUrl}${Astro.url.pathname}`} /> -->
  <!-- <link rel="alternate" hreflang="ja" href={`${siteUrl}/ja${Astro.url.pathname}`} /> -->

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />

  <!-- Google Fonts: preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;700&family=Noto+Sans+TC:wght@300;400;500;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />

  <!-- JSON-LD: WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebSite)} />
  <!-- JSON-LD: Organization -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdOrganization)} />

  <slot name="head" />
</head>
<body class="min-h-screen flex flex-col" style="background-color: #FAFBFC; color: #1E293B;">

  <!-- Navigation -->
  <header class="nav-header" id="nav-header">
    <div class="max-w-6xl mx-auto px-6 w-full flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 no-underline group">
        <div style="line-height: 1;">
          <span class="nav-logo-h2">H₂</span>
          <span class="nav-logo-text"> Water Lab</span>
        </div>
        <span style="font-size: 0.7rem; color: var(--color-slate); letter-spacing: 0.06em; font-weight: 300; display: block; margin-top: 2px;">氫水研究室</span>
      </a>

      <!-- Nav Links (Desktop) -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="/" class="nav-link">首頁</a>
        <a href="/blog" class="nav-link">研究文章</a>
        <a href="/categories" class="nav-link">分類瀏覽</a>
        <a href="/blog" class="btn btn-primary" style="padding: 8px 18px; font-size: 0.8rem;">探索研究</a>
      </nav>

      <!-- Mobile Nav Toggle (simple) -->
      <button class="md:hidden flex flex-col gap-1.5 p-2" id="mobile-menu-btn" aria-label="選單">
        <span style="display:block; width:20px; height:2px; background: var(--color-graphite);"></span>
        <span style="display:block; width:20px; height:2px; background: var(--color-graphite);"></span>
        <span style="display:block; width:14px; height:2px; background: var(--color-graphite);"></span>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden absolute top-full left-0 right-0 border-t" style="background: rgba(250,251,252,0.98); backdrop-filter: blur(12px); border-color: var(--color-silver);">
      <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-2">
        <a href="/" class="nav-link py-2">首頁</a>
        <a href="/blog" class="nav-link py-2">研究文章</a>
        <a href="/categories" class="nav-link py-2">分類瀏覽</a>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="flex-1" style="padding-top: 64px;">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-8">

        <!-- Brand Column -->
        <div>
          <div class="footer-brand">H₂ Water Lab</div>
          <p class="footer-tagline" style="margin-top: 0.5rem;">
            用科學，重新認識水<br />
            <span style="opacity: 0.6;">Science-backed hydrogen water research</span>
          </p>
          <p class="footer-tagline" style="margin-top: 1rem; font-size: 0.78rem;">
            整合 PubMed 臨床研究，<br />幫你做出有根據的健康選擇。
          </p>
        </div>

        <!-- Navigation Column -->
        <div>
          <div class="footer-heading">內容</div>
          <a href="/blog" class="footer-link">所有文章</a>
          <a href="/categories" class="footer-link">分類瀏覽</a>
          <a href="/categories/氫水科學" class="footer-link">氫水科學</a>
          <a href="/blog" class="footer-link">產品評測</a>
          <a href="/blog" class="footer-link">使用指南</a>
        </div>

        <!-- Contact Column -->
        <div>
          <div class="footer-heading">關於</div>
          <a href="/" class="footer-link">關於本站</a>
          <a href="/" class="footer-link">編輯方針</a>
          <a href="/" class="footer-link">引用資料</a>
          <div style="margin-top: 1rem;">
            <div class="footer-heading" style="margin-bottom: 0.5rem;">聯絡</div>
            <p style="font-size: 0.8rem; color: var(--color-slate);">research@h2water.co</p>
          </div>
        </div>
      </div>

      <!-- Footer Bottom -->
      <div class="footer-bottom">
        <span>© {new Date().getFullYear()} H2 Water Lab ／ 氫水研究室</span>
        <span style="font-size: 0.75rem; opacity: 0.6;">本站內容僅供教育參考，不構成醫療建議。</span>
      </div>
    </div>
  </footer>

  <!-- Nav Scroll Script -->
  <script>
    const navHeader = document.getElementById('nav-header');
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    // Scroll blur
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        navHeader?.classList.add('scrolled');
      } else {
        navHeader?.classList.remove('scrolled');
      }
    });

    // Mobile menu toggle
    mobileMenuBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
